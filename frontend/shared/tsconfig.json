{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@backend/*": ["../../backend/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/types/**/*.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "../loginpage/**/*.ts",
    "../loginpage/**/*.tsx",
    "../dashboard/**/*.ts",
    "../dashboard/**/*.tsx",
    "../alerts/**/*.ts",
    "../alerts/**/*.tsx",
    "../deepfocus/**/*.ts",
    "../deepfocus/**/*.tsx",
    "../aimentor/**/*.ts",
    "../aimentor/**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}

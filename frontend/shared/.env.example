# Copy this file to frontend/shared/.env.local (same folder as package.json — NOT inside src/)

# Notion — required for sign-in / sign-up
NOTION_API_KEY=
NOTION_USERS_DATABASE_ID=
NOTION_USERS_DATA_SOURCE_ID=

# Notion user profiles (optional — cookie fallback when unset)
NOTION_PROFILES_DATABASE_ID=
NOTION_PROFILES_DATA_SOURCE_ID=

# Notion Resources library (optional — seeded fallback when unset)
NOTION_RESOURCES_DATABASE_ID=
NOTION_RESOURCES_DATA_SOURCE_ID=

# Notion Study Plans (optional — cookie fallback when unset)
NOTION_STUDY_PLANS_DATABASE_ID=
NOTION_STUDY_PLANS_DATA_SOURCE_ID=

# Coral — all integrations use `coral sql` (logs show: [coral] query → SELECT ...)
CORAL_ENABLED=false
CORAL_BIN=coral
CORAL_TIMEOUT_MS=30000
# Log every Coral SQL query (default on). Set false to silence.
CORAL_LOG_QUERIES=true
# Cache Notion `data_source_pages` reads (ms). Higher = fewer slow Coral subprocess calls.
CORAL_PAGES_CACHE_TTL_MS=600000
CORAL_DEBUG_SQL=false
# Local JSONL store for focus sessions, mock submissions (absolute path)
CORAL_DATA_DIR=

# Direct REST fallback only when explicitly enabled (default: Coral-only, errors if SQL fails)
CORAL_OPENROUTER_GATEWAY_FALLBACK=false
CORAL_CALENDAR_GATEWAY_FALLBACK=false
# Bypass Coral SQL entirely (debug only)
CORAL_OPENROUTER_DIRECT=false
CORAL_CALENDAR_DIRECT=false

# OpenRouter — mentor AI
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_APP_NAME=DhruvYantra
OPENROUTER_ENABLED=false

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata
GOOGLE_CALENDAR_ENABLED=false

# Google Drive Vault
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_DRIVE_ENABLED=false

# Telegram Parent Connect
TELEGRAM_BOT_TOKEN=
TELEGRAM_PARENT_CHAT_ID=
TELEGRAM_ENABLED=false

NEXT_PUBLIC_APP_URL=http://localhost:3001
